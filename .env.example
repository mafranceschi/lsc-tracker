# ─────────────────────────────────────────────
#  LSC Tracker · Configuración
# ─────────────────────────────────────────────

# Activar o desactivar la base de datos de historial
# true  → guarda cada análisis y purga registros viejos automáticamente
# false → modo solo visualización, sin persistencia
ENABLE_DB=false

# Puerto en el que corre el servidor (default: 3000)
PORT=3000

# Días de retención de registros en la DB (default: 30, mínimo: 1)
RETENTION_DAYS=30

# Objetivo mínimo de horas semanales por agente (default: 12)
# La barra de progreso se completa al llegar a este valor; por encima queda al 100%.
GOAL_HOURS=12

# Tamaño máximo del log a analizar en MB (default: 10)
# Subilo si tus logs superan ese tamaño.
MAX_LOG_MB=10

# Clave de API para proteger el acceso (opcional)
# Si se define, todos los requests a /api/logs requieren el header:
#   X-API-Key: tu_clave
# Dejar vacío o comentado para deshabilitar la autenticación.
# API_KEY=cambia_esto_por_una_clave_segura
